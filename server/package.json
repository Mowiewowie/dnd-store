{
  "name": "dnd-store-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env.development --experimental-sqlite --watch src/index.js",
    "start": "node --env-file=.env --experimental-sqlite src/index.js",
    "test": "node --env-file=.env.test --experimental-sqlite --test --test-concurrency=1 \"src/__tests__/*.test.js\"",
    "test:watch": "node --env-file=.env.test --experimental-sqlite --test --watch \"src/__tests__/*.test.js\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "supertest": "^6.3.4"
  }
}
